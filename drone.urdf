<?xml version="1.0"?>
<robot name="drone">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.01" ixy="0" ixz="0"
        iyy="0.01" iyz="0"
        izz="0.01"/>
    </inertial>
  </link>

  <link name="prop_fl">
    <visual>
      <geometry>
        <box size="0.14 0.05 0.01"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.00001" ixy="0" ixz="0"
        iyy="0.00001" iyz="0"
        izz="0.00001"/>
    </inertial>
  </link>
  <joint name="prop_fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="prop_fl"/>
    <origin xyz="0.15 0.15 0.05"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="prop_fr">
    <visual>
      <geometry>
        <box size="0.14 0.05 0.01"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.00001" ixy="0" ixz="0"
        iyy="0.00001" iyz="0"
        izz="0.00001"/>
    </inertial>
  </link>
  <joint name="prop_fr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="prop_fr"/>
    <origin xyz="0.15 -0.15 0.05"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="prop_rl">
    <visual>
      <geometry>
        <box size="0.14 0.05 0.01"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.00001" ixy="0" ixz="0"
        iyy="0.00001" iyz="0"
        izz="0.00001"/>
    </inertial>
  </link>
  <joint name="prop_rl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="prop_rl"/>
    <origin xyz="-0.15 0.15 0.05"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="prop_rr">
    <visual>
      <geometry>
        <box size="0.14 0.05 0.01"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.00001" ixy="0" ixz="0"
        iyy="0.00001" iyz="0"
        izz="0.00001"/>
    </inertial>
  </link>
  <joint name="prop_rr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="prop_rr"/>
    <origin xyz="-0.15 -0.15 0.05"/>
    <axis xyz="0 0 1"/>
  </joint>

</robot>
